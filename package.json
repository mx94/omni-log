{
  "name": "omni-log-monorepo",
  "private": true,
  "engines": {
    "node": ">=12.2.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "format": "prettier --write .",
    "lint": "eslint packages/*/src/**",
    "docs": "vitepress dev docs",
    "build-docs": "vitepress build docs",
    "serve-docs": "vitepress serve docs",
    "release": "ts-node scripts/release.ts",
    "ci-publish": "ts-node scripts/publishCI.ts",
    "build-log": "pnpm --filter @omni-log/log-core run build && pnpm -filter @omni-log/log-mini run build && pnpm -filter @omni-log/log-web run build",
    "ci-docs": "run-s build-docs"
  },
  "devDependencies": {
    "@manypkg/get-packages": "^2.2.0",
    "@microsoft/api-extractor": "^7.19.5",
    "@types/fs-extra": "^9.0.13",
    "@types/git-semver-tags": "^4.1.1",
    "@types/prompts": "^2.0.14",
    "@types/semver": "^7.3.9",
    "@typescript-eslint/eslint-plugin": "^5.11.0",
    "@typescript-eslint/parser": "^5.11.0",
    "conventional-changelog-cli": "^2.2.2",
    "eslint": "^8.8.0",
    "eslint-define-config": "^1.2.4",
    "eslint-plugin-node": "^11.1.0",
    "execa": "^5.1.1",
    "fs-extra": "^10.0.0",
    "git-semver-tags": "^4.1.1",
    "lint-staged": "^12.3.3",
    "minimist": "^1.2.5",
    "node-fetch": "^2.6.6",
    "npm-run-all": "^4.1.5",
    "picocolors": "^1.0.0",
    "prettier": "2.5.1",
    "prompts": "^2.4.2",
    "rimraf": "^3.0.2",
    "rollup": "^2.59.0",
    "semver": "^7.3.5",
    "simple-git-hooks": "^2.7.0",
    "sirv": "^2.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec ts-node scripts/verifyCommit.ts $1"
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ],
    "packages/*/{src,types}/**/*.ts": [
      "eslint --ext .ts"
    ],
    "packages/**/*.d.ts": [
      "eslint --ext .ts"
    ]
  },
  "packageManager": "pnpm@6.30.0",
  "dependencies": {
    "@types/node": "^20.2.0",
    "esbuild": "^0.17.19"
  }
}
