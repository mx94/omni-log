{
  "name": "@omni-log/log-mini",
  "version": "0.1.2",
  "author": "curry.ma",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mx94/omni-log.git"
  },
  "homepage": "https://github.com/mx94/omni-log",
  "keywords": [
    "miniprogram",
    "log",
    "report",
    "wechat",
    "alipay",
    "logger",
    "monitor"
  ],
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "node": "./dist/esm.js",
        "default": "./dist/esm.js"
      },
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "rimraf dist && run-p dev-types dev-watch dev-watch-esm",
    "dev-types": "tsc -p . -w --incremental --emitDeclarationOnly",
    "dev-watch": "esbuild src/index.ts --watch --bundle --platform=node --target=node12 --outfile=dist/index.js --define:__LOG_VERSION__='\"'$(node -p \"require('./package.json').version\")'\"'",
    "dev-watch-esm": "esbuild src/index.ts --watch --format=esm --bundle --platform=node --target=node12 --outfile=dist/esm.js --define:__LOG_VERSION__='\"'$(node -p \"require('./package.json').version\")'\"'",
    "build": "rimraf dist && run-s build-bundle build-bundle-esm build-types",
    "build-bundle": "esbuild src/index.ts --bundle --platform=browser --target=es2015 --outfile=dist/index.js --minify=true --keep-names --legal-comments=none --define:__LOG_VERSION__='\"'$(node -p \"require('./package.json').version\")'\"'",
    "build-bundle-esm": "esbuild src/index.ts --bundle --tree-shaking=true --format=esm --platform=browser --target=es2015 --outfile=dist/esm.js --minify=true --keep-names --legal-comments=none --define:__LOG_VERSION__='\"'$(node -p \"require('./package.json').version\")'\"'",
    "patch-dist": "ts-node ../../scripts/patchEsbuildDist.ts dist/index.js vuePlugin",
    "build-types": "tsc -p . --emitDeclarationOnly --outDir temp && api-extractor run && rimraf temp",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@omni-log/error": "file:../error",
    "@omni-log/log-core": "file:../log-core"
  }
}
