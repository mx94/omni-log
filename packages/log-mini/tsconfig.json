{
  "include": ["src", "env.d.ts", "global.d.ts"],
  "exclude": ["**/*.spec.ts"],
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@omni-log/log-core": ["../log-core/src/index"],
      "@omni-log/error": ["../error/src/index"]
    }
  }
}
